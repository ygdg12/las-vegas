# Copy to .env for local `npm run dev` (Vite loads these for the dev API route)
# Resend (https://resend.com) — used by /api/booking on Vercel and locally
RESEND_API_KEY=re_xxxxxxxx
# Where booking notifications are delivered (no spaces). With Resend’s test sender
# onboarding@resend.dev, you can usually only send TO the email you signed up with until you add a domain.
BOOKING_TO_EMAIL=reservations@yourdomain.com
# Must be a verified sender in Resend (onboarding@resend.dev works for testing with limits above)
RESEND_FROM=booking@yourdomain.com
